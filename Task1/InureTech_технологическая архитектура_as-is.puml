    }

    YC_BlueBlock(postgresVmBlock, "VM 1") {
            YC_Managed_Kubernetes(postgresVm, " ")

            YC_SecurityGroup(postgresMasterGroup, "PosgreSQL (master)") {
                YC_Managed_PostgreSQL(postgresMaster)
            }
    }
}

Rel(userBrowser, availabilityZone1, " ")


Rel(insurtechNamespace, postgresMasterGroup, " ", $techn="TCP")


@enduml