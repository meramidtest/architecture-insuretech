@startuml
!pragma layout smetana

!include /Users/vdor/Projects/tmp/yandex-cloud-plantuml/YandexCloud.puml
!include /Users/vdor/Projects/tmp/yandex-cloud-plantuml/YandexCloudContainers.puml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

