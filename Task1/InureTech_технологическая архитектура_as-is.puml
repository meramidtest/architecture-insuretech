    YC_BlueBlock(k8sClusterBlock, "Kubernetes Cluster 1") {
        YC_Managed_Kubernetes(k8sCluster, " ")

        YC_SecurityGroup(insurtechNamespace, "InsecureTech namespace") {
            YC_Managed_Kubernetes(insurtechApp)
